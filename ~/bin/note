#!/bin/bash

SCRATCH_LOCATION=~/docs/notes/scratch.md

# 1. Attempt to find the git root directory name
# If not in a git repo, fallback to the current directory name
PROJECT_PATH=$(git rev-parse --show-toplevel 2>/dev/null)
if [ -n "$PROJECT_PATH" ]; then
  PROJECT_NAME=$(basename "$PROJECT_PATH")
else
  PROJECT_NAME=$(basename "$PWD")
fi

# 2. Append to the scratchpad
# We keep your existing date format but append the project context in brackets
echo "## $(date '+%Y-%m-%d %H:%M') [$PROJECT_NAME]" >> "$SCRATCH_LOCATION"
echo "$1" >> "$SCRATCH_LOCATION"
echo "" >> "$SCRATCH_LOCATION"
